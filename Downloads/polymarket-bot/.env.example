# ── POLYMARKET ──────────────────────────────────────────────
# Export from: polymarket.com → Account → Private Key
POLYMARKET_PRIVATE_KEY=0xyour_private_key_here

# Your Polygon wallet address (public key / funder address)
POLYMARKET_FUNDER=0xyour_wallet_address_here

# Signature type:
#   0 = MetaMask / hardware wallet (EOA)
#   1 = Email / Magic.link wallet  ← most common
POLYMARKET_SIG_TYPE=1

# ── GOOGLE SHEETS ────────────────────────────────────────────
# Name of your Google Sheet (exact, case-sensitive)
SHEET_NAME=BettingSystem

# ── EMAIL ALERTS ─────────────────────────────────────────────
ALERT_EMAIL=your@gmail.com
# Generate at: Google Account → Security → App Passwords
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── STRATEGY SETTINGS ────────────────────────────────────────
# Min volume (USDC) for a market to be considered
MIN_VOLUME=50000

# Min liquidity in order book to consider a market
MIN_LIQUIDITY=5000

# Kelly fraction (0.25 = quarter-Kelly — safer)
KELLY_FRACTION=0.25

# Max single trade size in USDC
MAX_TRADE_USDC=25

# Min USDC to keep in wallet (never trade below this)
MIN_WALLET_RESERVE=20

# Edge threshold: model prob must exceed market price by this much
EDGE_THRESHOLD=0.07

# Loop interval in seconds
LOOP_INTERVAL=120

# Paper trade mode: "true" = log only, no real orders placed
PAPER_TRADE=true
